# Production (Vercel):
#   Option A (Recommended): leave VITE_API_URL empty
#     -> calls go to /api/* on the Vercel host
#     -> vercel.json rewrites them to the EC2 backend (avoids CORS, hides backend URL)
#   Option B: set direct URL to backend (requires CORS allowlist on backend)
#     VITE_API_URL=http://your-ec2-public-dns
VITE_API_URL=

# Local dev: Vite proxy target (see vite.config.ts)
# Point at the running backend - localhost when you run `dotnet run`,
# or the EC2 DNS if you want the local frontend to hit the deployed API.
VITE_API_PROXY_TARGET=http://localhost:5076
