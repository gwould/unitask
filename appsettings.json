{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=unitask;User Id=sa;Password=YourPassword123!;Encrypt=false;TrustServerCertificate=true;Connection Timeout=30;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "JwtSecret": "your-very-long-secret-key-at-least-32-characters-long-for-hs256-algorithm!",
    "JwtExpirationMinutes": 1440,
    "RefreshTokenExpirationDays": 7,
    "MaxUploadSizeBytes": 52428800,
    "AllowedOrigins": "http://localhost:5173,http://localhost:3000"
  },
  "PaymentSettings": {
    "EscrowReleaseDelayDays": 3,
    "WithdrawalProcessingDays": 3,
    "MinimumWithdrawalAmount": 100000,
    "TransactionFeePercent": 0,
    "Currency": "VND"
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "EnableSsl": true,
    "EmailAddress": "your-email@gmail.com",
    "EmailPassword": "your-app-password",
    "EmailDisplayName": "UniTask"
  },
  "StorageSettings": {
    "Provider": "AzureBlob",
    "AzureBlobConnectionString": "DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net",
    "AzureContainerName": "uploads",
    "LocalStoragePath": "./uploads"
  }
}
